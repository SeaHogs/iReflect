POSTGRES_USER=ireflectadmin
POSTGRES_PASSWORD=wereflect2
POSTGRES_DB=ireflectadmin

# LightRAG configuration mirrors the upstream sample so we can manage every
# setting from a single project-wide .env file. Update these values as needed
# before running docker compose.
LIGHTRAG_HOST=0.0.0.0
LIGHTRAG_PORT=9621
LIGHTRAG_NAMESPACE_PREFIX=lightrag
LIGHTRAG_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

LIGHTRAG_LOG_LEVEL=INFO
LIGHTRAG_VERBOSE=False
LIGHTRAG_TIMEOUT=300

LIGHTRAG_MAX_ASYNC=4
LIGHTRAG_EMBEDDING_DIM=1024
LIGHTRAG_MAX_EMBED_TOKENS=8192

# Query-time parameters
LIGHTRAG_HISTORY_TURNS=3
LIGHTRAG_COSINE_THRESHOLD=0.2
LIGHTRAG_TOP_K=60
LIGHTRAG_MAX_TOKEN_TEXT_CHUNK=4000
LIGHTRAG_MAX_TOKEN_RELATION_DESC=4000
LIGHTRAG_MAX_TOKEN_ENTITY_DESC=4000

# Index-time parameters
LIGHTRAG_CHUNK_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP_SIZE=100
LIGHTRAG_MAX_TOKENS=32768
LIGHTRAG_MAX_TOKEN_SUMMARY=500
LIGHTRAG_SUMMARY_LANGUAGE=English

# LightRAG authentication
LIGHTRAG_API_KEY=

# Model bindings
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_BINDING_HOST=https://api.openai.com
LIGHTRAG_LLM_MODEL=gpt-4o-mini
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_BINDING_HOST=https://api.openai.com
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large

# Provide your OpenAI key once; docker-compose will forward it to both
# OPENAI_API_KEY and LLM_BINDING_API_KEY inside the LightRAG container so the
# service never falls back to a hard-coded credential.
LIGHTRAG_OPENAI_API_KEY=
